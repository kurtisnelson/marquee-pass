{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth !== null && $uid === auth.uid",
        ".write": "auth !== null && $uid === auth.uid",
        "shows": {
          ".validate": "newData.hasChildren() || !newData.exists()",
          "$showId": {
            ".validate": "!newData.exists() || newData.hasChildren(['id', 'title', 'status'])",
            "id": {
              ".validate": "newData.isNumber() && (newData.val() + '' == $showId)"
            },
            "title": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
            },
            "theater": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 150)"
            },
            "date": {
              ".validate": "!newData.exists() || newData.isNumber()"
            },
            "status": {
              ".validate": "newData.isString() && (newData.val() === 'SEEN' || newData.val() === 'WANT_TO_SEE' || newData.val() === 'TICKETED')"
            },
            "rating": {
              ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 5 && newData.parent().child('status').val() === 'SEEN')"
            },
            "notes": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1000)"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
